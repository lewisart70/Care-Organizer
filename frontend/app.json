{
  "expo": {
    "name": "Family Care Organizer",
    "slug": "family-care-organizer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "familycareorganizer",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.familycareorganizer.app",
      "buildNumber": "4",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Record voice notes to document caregiving observations and daily care activities",
        "NSCameraUsageDescription": "Take photos to identify care recipients and document care activities",
        "NSPhotoLibraryUsageDescription": "Choose profile photos from your library for care recipient identification",
        "NSHealthShareUsageDescription": "Share health data to help coordinate care for your loved ones",
        "NSHealthUpdateUsageDescription": "Update health records to maintain accurate care information",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.477062471666-2a4df0o10g8b4fkh9asstlln7mpo93h1"
            ]
          }
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.familycareorganizer.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#D97757"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#D97757"
        }
      ],
      "expo-secure-store",
      [
        "expo-audio",
        {
          "microphonePermission": "Record voice notes to document caregiving observations and daily care activities"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Take photos to identify care recipients and document care activities",
          "photosPermission": "Choose profile photos from your library for care recipient identification"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-apple-authentication",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "c1e35928-bb06-4597-a866-6312eb58b24b"
      },
      "router": {}
    },
    "owner": "cre8tve"
  }
}
